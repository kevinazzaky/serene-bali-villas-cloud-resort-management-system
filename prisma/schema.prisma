generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  MANAGER
  OWNER
  ADMIN
}

enum VillaStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum ServiceRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TransactionType {
  BOOKING_PAYMENT
  REFUND
  ADJUSTMENT
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  role          Role      @default(GUEST)

  accounts      Account[]
  sessions      Session[]

  bookings      Booking[]
  serviceRequests ServiceRequest[]
  conciergeMessages ConciergeMessage[]
  auditLogs      AuditLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Villa {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String      @db.Text
  location    String?
  capacity    Int
  bedrooms    Int
  bathrooms   Int
  basePrice   Decimal     @db.Decimal(12, 2)
  status      VillaStatus @default(ACTIVE)

  images      VillaImage[]
  amenities   VillaAmenity[]
  bookings    Booking[]
  maintenanceTickets MaintenanceTicket[]
  iotDevices  IotDevice[]
  sustainabilityMetrics SustainabilityMetric[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VillaImage {
  id        String @id @default(cuid())
  villaId   String
  imageUrl  String
  altText   String?
  sortOrder Int    @default(0)

  villa Villa @relation(fields: [villaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model VillaAmenity {
  id      String @id @default(cuid())
  villaId String
  name    String
  icon    String?

  villa Villa @relation(fields: [villaId], references: [id], onDelete: Cascade)
}

model Booking {
  id          String        @id @default(cuid())
  guestId     String
  villaId     String
  checkIn     DateTime
  checkOut    DateTime
  adults      Int
  children    Int           @default(0)
  status      BookingStatus @default(PENDING)
  totalAmount Decimal       @db.Decimal(12, 2)
  note        String?       @db.Text

  guest       User          @relation(fields: [guestId], references: [id])
  villa       Villa         @relation(fields: [villaId], references: [id])
  payment     Payment?
  invoice     Invoice?
  serviceRequests ServiceRequest[]
  transactions Transaction[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([villaId, checkIn, checkOut])
  @@index([guestId])
  @@index([status])
}

model Payment {
  id        String        @id @default(cuid())
  bookingId String        @unique
  provider  String        @default("DUMMY")
  currency  String        @default("IDR")
  amount    Decimal       @db.Decimal(12, 2)
  status    PaymentStatus @default(UNPAID)
  reference String?
  paidAt    DateTime?

  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id        String        @id @default(cuid())
  bookingId String        @unique
  invoiceNo String        @unique
  total     Decimal       @db.Decimal(12, 2)
  status    PaymentStatus @default(UNPAID)

  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceRequest {
  id        String               @id @default(cuid())
  guestId   String
  bookingId String?
  type      String
  message   String               @db.Text
  status    ServiceRequestStatus @default(OPEN)
  priority  Priority             @default(MEDIUM)

  guest     User                 @relation(fields: [guestId], references: [id])
  booking   Booking?             @relation(fields: [bookingId], references: [id])
  messages  ConciergeMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guestId])
  @@index([bookingId])
  @@index([status])
}

model ConciergeMessage {
  id        String @id @default(cuid())
  requestId String
  senderId  String
  message   String @db.Text

  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender    User           @relation(fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}

model MaintenanceTicket {
  id          String            @id @default(cuid())
  villaId      String
  title        String
  description  String?           @db.Text
  status       MaintenanceStatus @default(OPEN)
  priority     Priority          @default(MEDIUM)
  dueDate      DateTime?

  villa        Villa             @relation(fields: [villaId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model IotDevice {
  id         String @id @default(cuid())
  villaId    String
  deviceName String
  deviceType String
  status     String @default("ONLINE")

  villa      Villa @relation(fields: [villaId], references: [id], onDelete: Cascade)
  readings   IotReading[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model IotReading {
  id         String   @id @default(cuid())
  deviceId   String
  metric     String
  value      Float
  unit       String
  recordedAt DateTime @default(now())

  device     IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
}

model Transaction {
  id        String          @id @default(cuid())
  bookingId String?
  type      TransactionType
  amount    Decimal         @db.Decimal(12, 2)
  currency  String          @default("IDR")
  status    PaymentStatus   @default(UNPAID)

  booking   Booking?        @relation(fields: [bookingId], references: [id])

  createdAt DateTime @default(now())
}

model SustainabilityMetric {
  id      String   @id @default(cuid())
  villaId  String
  energy   Float?
  water    Float?
  date     DateTime

  villa    Villa    @relation(fields: [villaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([villaId, date])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  actor     User?    @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([entity, entityId])
}